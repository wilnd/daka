<navigation-bar title="好友运动成长助手" back="{{false}}" color="white" background="linear-gradient(135deg, #40E0D0 0%, #48D1CC 100%)"></navigation-bar>
<scroll-view class="page" scroll-y>
  <view class="container">
    <view wx:if="{{!hasUserInfo}}" class="auth-section">
      <!-- 欢迎区域 -->
      <view class="welcome-area">
        <view class="welcome-icon">🏃‍♂️</view>
        <text class="welcome-title">欢迎使用成长助手</text>
        <text class="welcome-desc">立即授权，开始你的运动成长之旅</text>
      </view>

      <!-- 头像选择 -->
      <view class="avatar-area">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
          <view class="avatar-edit-badge">
            <text class="edit-icon">✎</text>
          </view>
        </button>
        <text class="avatar-tip">点击更换头像</text>
      </view>

      <!-- 昵称输入 -->
      <view class="nickname-area">
        <input
          type="nickname"
          class="nickname-input"
          placeholder="请输入你的昵称"
          placeholder-class="nickname-placeholder"
          bindblur="onNicknameBlur"
          value="{{userInfo.nickName}}"
        />
      </view>

      <!-- 确认按钮 -->
      <button class="btn-primary confirm-auth" bindtap="onConfirmAuth">
        <text class="btn-text">开启成长之旅</text>
      </button>

      <!-- 隐私说明 -->
      <text class="privacy-tip">仅用于展示你的运动排名，不会收集其他信息</text>
    </view>
    <view wx:elif="{{loading}}" class="skeleton-wrap">
      <view class="skeleton-card">
        <view class="skeleton skeleton-title"></view>
        <view class="skeleton skeleton-btn"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton skeleton-text"></view>
        <view class="skeleton skeleton-text short"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton skeleton-stat"></view>
        <view class="skeleton skeleton-stat"></view>
        <view class="skeleton skeleton-stat"></view>
      </view>
    </view>
    <view wx:else class="main">
      <!-- 空状态：没有小组 -->
      <view wx:if="{{!currentGroup}}" class="empty-state">
        <view class="empty-icon">🏃</view>
        <text class="empty-title">欢迎使用成长助手</text>
        <text class="empty-desc">创建或加入一个小组，开始你的运动成长之旅</text>
        <view class="empty-actions">
          <button class="btn-primary" bindtap="goCreateGroup">创建小组</button>
          <button class="btn-secondary" bindtap="goJoinGroup">加入小组</button>
        </view>
      </view>
      <!-- 有小组时显示正常内容 -->
      <view wx:else>
        <view
          class="checkin-card"
          style="--btn-color: {{themeColor}}; --btn-color-rgb: {{themeColorRgb}}"
        >
          <view class="checkin-status {{checkedToday ? 'checked' : ''}}">
            <text class="status-text">{{checkedToday ? '今日已记录' : '发布动态'}}</text>
          </view>
          <view class="checkin-btn-wrapper">
            <button
              class="btn-primary checkin-btn {{checkedToday ? 'checked' : ''}} {{checkinAnimating ? 'animating' : ''}}"
              style="--btn-color: {{themeColor}}"
              hover-class="btn-hover"
              bindtap="onCheckin"
              disabled="{{!currentGroup || checkinAnimating}}"
            >
              <text wx:if="{{checkinAnimating}}">提交中...</text>
              <text wx:elif="{{checkedToday}}">继续记录</text>
              <text wx:else>发布记录</text>
            </button>
            <view wx:if="{{checkedToday}}" class="success-badge">
              <text class="badge-icon">✓</text>
            </view>
          </view>
        </view>
        <view wx:if="{{stats}}" class="stats-card">
          <view class="stat-item highlight">
            <text class="stat-value primary">{{stats.streak}}</text>
            <text class="stat-label">连胜天数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{stats.totalCount}}</text>
            <text class="stat-label">记录次数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{stats.totalDays}}</text>
            <text class="stat-label">记录天数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value {{stats.missStreak > 0 ? 'warn' : ''}}">{{stats.missStreak}}</text>
            <text class="stat-label">连续未记录</text>
          </view>
        </view>

        <!-- 排行榜 -->
        <view wx:if="{{currentGroup}}" class="rank-card">
          <view class="rank-header">
            <view class="group-selector" bindtap="showSwitchGroup">
              <text class="rank-title">{{currentGroup.name}}</text>
              <text class="arrow">▼</text>
            </view>
          </view>
          <view class="rank-tabs">
            <view class="rank-tab {{rankType === 'week' ? 'active' : ''}}" bindtap="switchRank" data-type="week">周榜</view>
            <view class="rank-tab {{rankType === 'month' ? 'active' : ''}}" bindtap="switchRank" data-type="month">月榜</view>
            <view class="rank-tab {{rankType === 'all' ? 'active' : ''}}" bindtap="switchRank" data-type="all">总榜</view>
          </view>
          <!-- 多维度切换 -->
          <view class="dimension-tabs">
            <view class="dimension-tab {{rankDimension === 'days' ? 'active' : ''}}" bindtap="switchRankDimension" data-dimension="days">记录天数</view>
            <view class="dimension-tab {{rankDimension === 'minutes' ? 'active' : ''}}" bindtap="switchRankDimension" data-dimension="minutes">运动时长</view>
            <view class="dimension-tab {{rankDimension === 'score' ? 'active' : ''}}" bindtap="switchRankDimension" data-dimension="score">平均成长值</view>
          </view>
          <!-- 统计对比 -->
          <view wx:if="{{myRank && myRank.minutes && myRank.days && myRank.score && groupAvg && !statsLoading}}" class="stats-compare">
            <view class="compare-header">
              <text class="compare-title">我的排名</text>
              <text class="compare-rank">第{{rankDimension === 'minutes' ? myRank.minutes.rank : rankDimension === 'days' ? myRank.days.rank : myRank.score.rank}}名 / {{totalMembers}}人</text>
            </view>
            <view class="compare-stats">
              <view class="compare-item">
                <text class="compare-value">{{rankDimension === 'minutes' ? myRank.minutes.totalMinutes : rankDimension === 'days' ? myRank.days.checkinDays : myRank.score.avgScore}}</text>
                <text class="compare-label">{{rankDimension === 'minutes' ? '分钟' : rankDimension === 'days' ? '天' : '成长值'}}</text>
              </view>
              <view class="compare-item group">
                <text class="compare-value">{{rankDimension === 'minutes' ? groupAvg.totalMinutes : rankDimension === 'days' ? groupAvg.checkinDays : groupAvg.avgScore}}</text>
                <text class="compare-label">群平均</text>
              </view>
            </view>
            <view class="compare-percent">
              <text wx:if="{{groupPercentiles}}">超越群内 {{rankDimension === 'minutes' ? groupPercentiles.minutes : rankDimension === 'days' ? groupPercentiles.days : groupPercentiles.score}}% 的用户</text>
            </view>
          </view>
          <view wx:if="{{statsLoading}}" class="rank-loading">加载统计中...</view>
          <view wx:elif="{{!currentRankList || currentRankList.length === 0}}" class="rank-empty">暂无数据</view>
          <view wx:else class="rank-list">
            <view wx:for="{{currentRankList || []}}" wx:key="userId" class="rank-item" bindtap="onViewUserMoments" data-user-id="{{item.userId}}" data-nick-name="{{item.nickName}}" data-avatar-url="{{item.avatarUrl}}">
              <view class="rank-index {{index < 3 ? 'top' : ''}}">{{index + 1}}</view>
              <image class="rank-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
              <text class="rank-name">{{item.nickName}}</text>
              <text class="rank-streak">{{rankDimension === 'minutes' ? item.totalMinutes + ' 分钟' : rankDimension === 'days' ? item.checkinDays + ' 天' : item.avgScore + ' 成长值'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 切换小组弹窗 -->
<view class="modal {{showSwitchModal ? 'show' : ''}}" bindtap="hideSwitchGroup" wx:if="{{showSwitchModal}}">
  <view class="modal-content" catchtap="stopPropagation">
    <text class="modal-title">切换小组</text>
    <view wx:for="{{groups || []}}" wx:key="_id" class="group-option {{item._id === currentGroup._id ? 'active' : ''}}" bindtap="selectGroup" data-id="{{item._id}}">
      <view class="group-option-info">
        <text>{{item.name}}</text>
        <text class="meta">成员 {{item.memberCount || 0}} 人</text>
      </view>
      <view class="group-option-actions">
        <text wx:if="{{item._id === currentGroup._id}}" class="default-tag">当前</text>
        <button wx:else class="btn-set-default" catchtap="setDefaultGroup" data-id="{{item._id}}">设为默认</button>
      </view>
    </view>
    <view class="modal-actions">
      <button class="btn-text" bindtap="goCreateGroup">创建新小组</button>
      <button class="btn-secondary" bindtap="hideSwitchGroup">取消</button>
    </view>
  </view>
</view>
