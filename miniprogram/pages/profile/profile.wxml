<navigation-bar title="我的" back="{{false}}" color="white" background="#2E8B57"></navigation-bar>
<scroll-view class="page" scroll-y>
  <view class="container">
    <view wx:if="{{!hasUserInfo}}" class="need-auth">
      <text>请先完成授权</text>
      <navigator url="/pages/index/index" class="link">去首页</navigator>
    </view>
    <view wx:else class="content">
      <view class="user-card" bindtap="onEditUserInfo">
        <image 
          class="avatar" 
          src="{{userInfo.avatarUrl}}" 
          mode="aspectFill"
          catchtap="onViewMyMoments"
        ></image>
        <view class="user-info">
          <text class="nick">{{userInfo.nickName}}</text>
          <text class="edit-hint">点击修改信息</text>
        </view>
        <text class="arrow">></text>
      </view>
      <view wx:if="{{currentGroup}}" class="stats-card">
        <view class="stat-item">
          <text class="stat-value primary">{{stats.totalDays || 0}}</text>
          <text class="stat-label">总打卡天数</text>
        </view>
        <view class="stat-item">
          <text class="stat-value primary">{{stats.streak || 0}}</text>
          <text class="stat-label">当前连胜</text>
        </view>
        <view class="stat-item">
          <text class="stat-value {{(stats.missStreak || 0) > 0 ? 'warn' : ''}}">{{stats.missStreak || 0}}</text>
          <text class="stat-label">连续未打卡</text>
        </view>
      </view>
      <view class="menu-list">
        <navigator url="/pages/calendar/calendar" class="menu-item">
          <text>打卡日历</text>
          <text class="arrow">></text>
        </navigator>
        <view class="menu-item" bindtap="showRecords">
          <text>打卡记录</text>
          <text class="arrow">></text>
        </view>
        <view class="menu-item" bindtap="genRemindCopy">
          <text>生成未打卡@文案</text>
          <text class="arrow">></text>
        </view>
        <view class="menu-item" bindtap="subscribeRemind">
          <text>订阅打卡提醒</text>
          <text class="subscribe-status {{isSubscribed ? 'subscribed' : ''}}">{{isSubscribed ? '已开启' : '未订阅'}}</text>
          <text class="arrow">></text>
        </view>
        <navigator url="/pages/contact-admin/contact-admin" class="menu-item">
          <text>联系管理员</text>
          <text class="arrow">></text>
        </navigator>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 打卡记录弹窗 -->
<view class="modal {{showRecordsModal ? 'show' : ''}}" catchtap="hideRecords" wx:if="{{showRecordsModal}}">
  <view class="modal-content records-modal" catchtap="">
    <text class="modal-title">打卡记录</text>
    <scroll-view scroll-y class="records-list">
      <view wx:for="{{records || []}}" wx:key="_id" class="record-item">
        <view class="record-left">
          <text class="record-date">{{item.date}}</text>
          <text wx:if="{{item.groupName}}" class="record-group">{{item.groupName}}</text>
        </view>
        <text class="tag {{item.isMakeup ? 'makeup' : ''}}">{{item.isMakeup ? '补卡' : ''}}</text>
      </view>
      <view wx:if="{{records.length === 0}}" class="empty-records">暂无记录</view>
    </scroll-view>
    <button class="btn-secondary" bindtap="hideRecords">关闭</button>
  </view>
</view>

<!-- 编辑用户信息弹窗 -->
<view class="modal {{showEditModal ? 'show' : ''}}" catchtap="hideEditModal" wx:if="{{showEditModal}}">
  <view class="modal-content" catchtap="">
    <text class="modal-title">修改个人信息</text>
    <view class="edit-form">
      <button class="btn-primary auth-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-preview" src="{{editingInfo.avatarUrl}}" mode="aspectFill"></image>
        <text class="avatar-tip">点击更换头像</text>
      </button>
      <input type="nickname" class="nickname-input" placeholder="请输入昵称" value="{{editingInfo.nickName}}" bindblur="onNicknameInput" />
      <view class="modal-btns">
        <button class="btn-secondary" bindtap="hideEditModal">取消</button>
        <button class="btn-primary" bindtap="saveUserInfo">保存</button>
      </view>
    </view>
  </view>
</view>

<!-- 提醒时间选择弹窗 -->
<view class="modal {{showTimePickerModal ? 'show' : ''}}" catchtap="hideTimePickerModal" wx:if="{{showTimePickerModal}}">
  <view class="modal-content" catchtap="">
    <text class="modal-title">设置提醒时间</text>
    <view class="time-picker-wrapper">
      <picker mode="time" value="{{remindTime}}" start="00:00" end="23:59" bindchange="onTimeChange">
        <view class="time-display">
          <text class="time-value">{{remindTime}}</text>
          <text class="time-hint">点击选择时间</text>
        </view>
      </picker>
    </view>
    <view class="modal-btns">
      <button class="btn-secondary" bindtap="hideTimePickerModal">取消</button>
      <button class="btn-primary" bindtap="saveRemindTime">保存</button>
    </view>
  </view>
</view>
