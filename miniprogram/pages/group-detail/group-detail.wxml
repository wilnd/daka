<navigation-bar title="{{group.name || '小组详情'}}" back="{{true}}" color="white" background="{{themeColor}}"></navigation-bar>
<scroll-view class="page" scroll-y>
  <view class="container">
    <view wx:if="{{loading}}" class="loading-wrap">
      <view class="loading-spinner"></view>
      <text>加载中</text>
    </view>
    <view wx:else class="content">
      <!-- 邀请码区域 -->
      <view class="invite-section">
        <view class="invite-header">
          <view class="invite-label">邀请码</view>
          <view wx:if="{{isAdmin}}" class="invite-toggle" bindtap="toggleInviteEnabled">
            <text class="toggle-text {{inviteEnabled ? 'on' : ''}}">{{inviteEnabled ? '已开启' : '已关闭'}}</text>
          </view>
        </view>
        <view class="invite-code-display" wx:if="{{inviteEnabled}}">
          <text class="code-text">{{group.inviteCode || '-'}}</text>
          <button class="btn-copy" bindtap="copyInvite">复制</button>
        </view>
        <view class="invite-disabled" wx:else>
          <text>邀请已关闭</text>
        </view>
        <view class="invite-actions" wx:if="{{isAdmin && inviteEnabled}}">
          <button class="btn-action" bindtap="showEditInvite">修改邀请码</button>
        </view>
        <text class="invite-hint" wx:if="{{inviteEnabled}}">分享邀请码，好友即可加入小组</text>
      </view>

      <!-- Tab 切换 -->
      <view class="tab-bar">
        <view class="tab-item {{currentTab === 'today' ? 'active' : ''}}" data-tab="today" bindtap="switchTab">
          <text>今日打卡</text>
        </view>
        <view class="tab-item {{currentTab === 'members' ? 'active' : ''}}" data-tab="members" bindtap="switchTab">
          <text>成员列表</text>
        </view>
        <view class="tab-item {{currentTab === 'rank' ? 'active' : ''}}" data-tab="rank" bindtap="switchTab">
          <text>打卡排行</text>
        </view>
      </view>

      <!-- 今日打卡 -->
      <view wx:if="{{currentTab === 'today'}}" class="section">
        <view wx:if="{{todayMembers.length === 0}}" class="empty-section">暂无成员</view>
        <view wx:for="{{todayMembers || []}}" wx:key="_id" class="member-row {{item.checked ? 'checked' : ''}}">
          <image class="avatar" src="{{item.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
          <text class="nick">{{item.nickName || '未知'}}</text>
          <text class="status {{item.checked ? 'checked' : 'unchecked'}}">{{item.checked ? '已打卡' : '未打卡'}}</text>
        </view>
      </view>

      <!-- 成员列表 -->
      <view wx:if="{{currentTab === 'members'}}" class="section">
        <view class="section-header">
          <text class="member-count">{{members.length}} 人</text>
        </view>
        <view wx:if="{{members.length === 0}}" class="empty-section">暂无成员</view>
        <view wx:for="{{members || []}}" wx:key="_id" class="member-row" bindtap="onMemberTap" data-member="{{item}}">
          <image class="avatar" src="{{item.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
          <text class="nick">{{item.nickName || '未知'}}</text>
          <text wx:if="{{item.role === 'admin'}}" class="role-badge">组长</text>
          <text class="arrow">></text>
        </view>
      </view>

      <!-- 打卡排行 -->
      <view wx:if="{{currentTab === 'rank'}}" class="section">
        <view wx:if="{{rankMembers.length === 0}}" class="empty-section">暂无数据</view>
        <view wx:for="{{rankMembers || []}}" wx:key="_id" class="rank-row {{index < 3 ? 'top' : ''}}">
          <view class="rank-num">{{index + 1}}</view>
          <image class="avatar" src="{{item.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
          <text class="nick">{{item.nickName || '未知'}}</text>
          <text class="days">{{item.checkinDays}} 天</text>
        </view>
      </view>

      <!-- 退小组按钮 -->
      <view class="quit-section">
        <button wx:if="{{!isAdmin}}" class="btn-danger" bindtap="onQuitGroup">退出小组</button>
        <button wx:if="{{isAdmin}}" class="btn-danger" bindtap="onDissolveGroup">解散小组</button>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 成员操作弹窗 -->
<view class="modal {{showMemberModal ? 'show' : ''}}" catchtap="hideMemberModal" wx:if="{{showMemberModal}}">
  <view class="modal-content" catchtap="">
    <text class="modal-title">{{selectedMemberNickName}}</text>
    <view class="member-info">
      <image class="avatar-large" src="{{selectedMemberAvatarUrl}}" mode="aspectFill"></image>
    </view>
    <view class="action-list">
      <view wx:if="{{canTransferAdmin}}" class="action-item" bindtap="onTransferAdmin">
        <text>转让组长</text>
      </view>
      <view wx:if="{{canRemoveMember}}" class="action-item danger" bindtap="onRemoveMember">
        <text>移除成员</text>
      </view>
      <view wx:if="{{isSelfMember}}" class="action-item danger" bindtap="onQuitGroup">
        <text>退出小组</text>
      </view>
    </view>
    <button class="btn-secondary" bindtap="hideMemberModal">取消</button>
  </view>
</view>

<!-- 确认退组/移除弹窗 -->
<view class="modal {{showConfirmModal ? 'show' : ''}}" catchtap="hideConfirmModal" wx:if="{{showConfirmModal}}">
  <view class="modal-content" catchtap="">
    <text class="modal-title">{{confirmTitle}}</text>
    <text class="confirm-desc">{{confirmContent}}</text>
    <view class="modal-btns">
      <button class="btn-secondary" bindtap="hideConfirmModal">取消</button>
      <button class="btn-danger" bindtap="confirmAction">确认</button>
    </view>
  </view>
</view>

<!-- 编辑邀请码弹窗 -->
<view class="modal {{showEditInviteModal ? 'show' : ''}}" catchtap="hideEditInvite" wx:if="{{showEditInviteModal}}">
  <view class="modal-content" catchtap="">
    <text class="modal-title">修改邀请码</text>
    <input class="modal-input" placeholder="输入新邀请码 4-10位" value="{{editInviteCode}}" maxlength="10" bindinput="onEditInviteInput" />
    <text class="input-hint">只能使用字母和数字</text>
    <view class="modal-btns">
      <button class="btn-secondary" bindtap="hideEditInvite">取消</button>
      <button class="btn-primary" bindtap="doUpdateInvite">保存</button>
    </view>
  </view>
</view>
