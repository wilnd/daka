<navigation-bar title="记录日历" back="{{true}}" color="white" background="{{themeColor}}"></navigation-bar>
<scroll-view class="page" scroll-y>
  <view class="container">
    <view wx:if="{{!hasOpenid}}" class="empty-tip">请先登录</view>
    <view wx:else>
      <view class="month-nav">
        <text class="nav-btn" bindtap="prevMonth">＜</text>
        <text class="month-title">{{displayMonth}}</text>
        <text class="nav-btn {{isCurrentMonth ? 'disabled' : ''}}" bindtap="nextMonth">＞</text>
      </view>
      <view class="makeup-tip">本月还能补 {{makeupRemain}} 次（只能补最近3天的哦）</view>

      <view class="calendar">
        <view class="weekday-row">
          <text wx:for="{{weekdays}}" wx:key="*this" class="weekday">{{item}}</text>
        </view>
        <view class="days-grid">
          <view
            wx:for="{{days}}"
            wx:key="date"
            class="day-cell {{item.empty ? 'empty' : ''}} {{item.checked ? 'checked' : ''}} {{item.makeup ? 'makeup' : ''}} {{item.canMakeup ? 'can-makeup' : ''}} {{item.isToday && !item.checked ? 'today' : ''}} {{item.date === selectedDate ? 'selected' : ''}}"
            bindtap="onDayTap"
            data-date="{{item.date}}"
            data-can="{{item.canMakeup}}"
            data-checked="{{item.checked}}">
            <text class="day-num">{{item.day}}</text>
            <text wx:if="{{item.makeup}}" class="day-tag">补</text>
          </view>
        </view>
      </view>

      <!-- 选中日期的记录 -->
      <view class="day-records">
        <view wx:if="{{!selectedDate}}" class="records-hint">
          <text class="hint-icon">👆</text>
          <text class="hint-text">点击已记录的日期查看详情</text>
        </view>
        <view wx:elif="{{selectedCheckins.length === 0}}" class="records-hint">
          <text class="hint-icon">📅</text>
          <text class="hint-text records-date-label">{{selectedDate}}</text>
          <text class="hint-text">暂无记录</text>
        </view>
        <view wx:else class="records-body">
          <view class="records-header">
            <text class="records-date">{{selectedDate}}</text>
            <text class="records-count">共 {{selectedCheckins.length}} 条</text>
          </view>
          <view wx:for="{{selectedCheckins}}" wx:key="_id" class="record-card">
            <view class="record-card-top">
              <text class="record-time">{{item.timeStr || ''}}</text>
              <view class="record-badges">
                <text wx:if="{{item.isMakeup}}" class="badge badge-makeup">补卡</text>
                <text wx:if="{{item.score && item.score.totalScore}}" class="badge badge-score">{{item.score.totalScore}}成长值</text>
              </view>
            </view>
            <view wx:if="{{item.content}}" class="record-detail">
              <view wx:if="{{item.content.duration}}" class="record-row">
                <text class="record-label">时长</text>
                <text class="record-value">{{item.content.duration}} {{item.content.durationUnit || '分钟'}}</text>
              </view>
              <view wx:if="{{item.content.text}}" class="record-row">
                <text class="record-label">内容</text>
                <text class="record-value record-text">{{item.content.text}}</text>
              </view>
              <view wx:if="{{item.content.photos && item.content.photos.length > 0}}" class="record-row">
                <text class="record-label">照片</text>
                <text class="record-value">{{item.content.photos.length}} 张</text>
              </view>
            </view>
            <view wx:if="{{!item.content || (!item.content.text && (!item.content.photos || item.content.photos.length === 0) && !item.content.duration)}}" class="record-plain">
              <text>已记录 ✓</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
