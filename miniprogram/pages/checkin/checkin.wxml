<navigation-bar title="记录" back="{{true}}" color="white" background="{{themeColor}}"></navigation-bar>
<view class="page">
  <!-- 记录表单 -->
  <view class="form">
    <!-- 记录类别 -->
    <view class="form-item">
      <view class="category-header">
        <text class="label">今天搞了啥</text>
        <text class="clear-btn" bindtap="onClearTag" wx:if="{{selectedTag}}">清除</text>
      </view>
      <!-- 已选择的标签展示 -->
      <view class="selected-tag" wx:if="{{selectedTag}}">
        <text class="tag-text">{{selectedTag ? categories[categoryIndex].name + ' · ' + subCategories[subCategoryIndex].name : ''}}</text>
      </view>
      <!-- Tags/胶囊选择器 -->
      <view class="category-tags">
        <view 
          wx:for="{{categoryGroups}}" 
          wx:key="*this"
          class="category-group"
        >
          <view class="group-title">{{item.category.name}}</view>
          <view class="tags-wrap">
            <view 
              wx:for="{{item.subCategories}}" 
              wx:for-item="sub" 
              wx:key="id"
              wx:for-index="subIdx"
              class="tag-item {{selectedTag === item.category.id + '_' + sub.id ? 'active' : ''}}"
              bindtap="onSelectTag"
              data-categoryid="{{item.category.id}}"
              data-subcategoryid="{{sub.id}}"
            >
              {{sub.name}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 时长输入 -->
    <view class="form-item" wx:if="{{categoryIndex >= 0}}">
      <view class="label-row">
        <text class="label">坚持了多久</text>
        <text class="label-tip">输入时长可获得 +X 成长值</text>
      </view>
      <view class="duration-input">
        <input 
          type="number"
          class="duration-field"
          placeholder="打算坚持多久？"
          value="{{duration}}"
          bindinput="onDurationInput"
        />
        <picker 
          range="{{durationUnits}}"
          value="{{durationUnitIndex}}"
          bindchange="onDurationUnitChange"
        >
          <view class="duration-unit">
            <text>{{durationUnits[durationUnitIndex]}}</text>
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 记录内容 -->
    <view class="form-item">
      <view class="label-row">
        <text class="label">想说的话</text>
        <text class="label-tip">填写内容可额外获得 +X 成长值</text>
      </view>
      <textarea 
        class="content-input"
        placeholder="今天感觉如何？有什么想记录的？" 
        maxlength="500"
        bindinput="onTextInput"
        value="{{text}}"
      ></textarea>
      <text class="word-count">{{text.length}}/500</text>
    </view>

    <!-- 照片上传 -->
    <view class="form-item">
      <view class="label-row">
        <text class="label">晒一张照片</text>
        <text class="label-tip">上传照片可额外获得 +X 成长值</text>
      </view>
      <view class="photos-grid">
        <view 
          wx:for="{{photos || []}}" 
          wx:key="index"
          class="photo-item"
        >
          <image src="{{item}}" mode="aspectFill" bindtap="onPreviewPhoto" data-url="{{item}}" data-index="{{index}}"></image>
          <view class="remove-btn" bindtap="onRemovePhoto" data-index="{{index}}">×</view>
        </view>
        <view class="add-photo" bindtap="onChoosePhoto" wx:if="{{photos && photos.length < maxPhotos}}">
          <text class="plus">+</text>
          <text class="desc">来一张</text>
        </view>
      </view>
    </view>

    <!-- 发布到成长墙 -->
    <view class="form-item switch-item">
      <view class="switch-left">
        <text class="label">晒到成长墙</text>
        <text class="desc">让大家都看到你的努力</text>
      </view>
      <switch
        checked="{{isPublishToMoments}}"
        color="#2E8B57"
        bindchange="onToggleMomentsPublish"
      />
    </view>

    <!-- 成长墙可见范围 -->
    <view class="form-item" wx:if="{{isPublishToMoments && momentsGroupRange && momentsGroupRange.length > 1}}">
      <text class="label">成长墙可见</text>
      <picker
        range="{{momentsGroupRange}}"
        range-key="name"
        value="{{momentsGroupIndex}}"
        bindchange="onMomentsGroupChange"
      >
        <view class="picker-value">
          <text>{{momentsGroupName || '所有群组'}}</text>
          <text class="arrow">></text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-bar">
    <button 
      class="submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : (mode === 'edit' ? '更新我的成就' : '记录我的成就')}}
    </button>
  </view>
</view>

<!-- 连胜动画 -->
<streak-animation 
  visible="{{showStreakAnimation}}" 
  streak="{{currentStreak}}"
  categoryId="{{checkinResult.categoryId}}"
  bind:complete="onStreakAnimationComplete"
  bind:skip="onSkipShare"
/>

<!-- 分享海报 -->
<share-poster 
  visible="{{showSharePoster}}" 
  checkinData="{{checkinResult}}"
  bind:close="onClosePoster"
  bind:skip="onSkipShare"
/>
