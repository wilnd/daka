<view class="poster-overlay" wx:if="{{visible}}" catchtap="onClose">
  <view class="poster-container" catchtap="preventTap">
    <view class="poster-header">
      <text class="title">分享到成长墙</text>
      <view class="close-btn" bindtap="onClose">×</view>
    </view>

    <view class="poster-content">
      <!-- 加载状态 -->
      <view class="poster-loading" wx:if="{{posterLoading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">海报生成中...</text>
      </view>
      
      <canvas 
        wx:if="{{!posterUrl}}"
        canvas-id="poster-canvas" 
        class="poster-canvas"
        style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
      ></canvas>
      <image 
        wx:if="{{posterUrl}}" 
        src="{{posterUrl}}" 
        mode="aspectFit" 
        class="poster-image {{posterLoading ? 'hidden' : ''}}"
      ></image>
    </view>

    <view class="poster-actions" wx:if="{{!posterLoading}}">
      <button 
        class="action-btn skip-btn"
        bindtap="onClose"
      >
        暂不分享
      </button>
      <button 
        class="action-btn save-btn"
        bindtap="onShareToFriends"
        wx:if="{{posterUrl}}"
      >
        <text class="btn-icon">📷</text>
        保存到相册
      </button>
      <button 
        class="action-btn timeline-btn"
        open-type="share"
        bindtap="onShareTimeline"
      >
        <text class="btn-icon">📤</text>
        分享给朋友
      </button>
    </view>

    <view class="poster-tips" wx:if="{{!posterLoading}}">
      <text class="tips-text">保存图片后，打开微信成长墙</text>
      <text class="tips-text">点击右上角「...」选择相册图片发布</text>
    </view>
  </view>
</view>
