<view class="streak-overlay" wx:if="{{visible}}" catchtap="preventTap">
  <!-- 彩色纸屑 -->
  <view class="confetti-container">
    <view 
      wx:for="{{particles || []}}" 
      wx:key="id"
      class="confetti"
      style="left: {{item.left}}%; background-color: {{item.color}}; animation-delay: {{item.delay}}s; animation-duration: {{item.duration}}s; width: {{item.size}}rpx; height: {{item.size}}rpx; transform: rotate({{item.rotate}}deg); opacity: {{item.opacity}};"
    ></view>
  </view>

  <!-- 火焰动画（5条，更猛烈） -->
  <view class="flame-container" wx:if="{{showFlame}}">
    <view class="flame flame-1"></view>
    <view class="flame flame-2"></view>
    <view class="flame flame-3"></view>
    <view class="flame flame-4"></view>
    <view class="flame flame-5"></view>
  </view>

  <!-- 连胜数字 -->
  <view class="streak-number {{showStreakNumber ? 'show' : ''}}">
    <text class="streak-text">{{displayStreak}}</text>
    <text class="streak-suffix" wx:if="{{streak >= 3}}">🔥</text>
  </view>

  <!-- 徽章 -->
  <view class="badge-container {{showBadge ? 'show' : ''}}" wx:if="{{badge}}">
    <view class="badge" style="background: linear-gradient(135deg, {{badge.color}}, {{badge.color}}88);">
      <text class="badge-icon">{{badge.icon}}</text>
    </view>
    <text class="badge-name">{{badge.name}}</text>
  </view>

  <!-- 星星闪烁 -->
  <view class="sparkles" wx:if="{{showSparkles}}">
    <view class="sparkle sparkle-1">🔥</view>
    <view class="sparkle sparkle-2">✨</view>
    <view class="sparkle sparkle-3">⭐</view>
    <view class="sparkle sparkle-4">✨</view>
    <view class="sparkle sparkle-5">🔥</view>
    <view class="sparkle sparkle-6">⭐</view>
  </view>

  <!-- 提示文字（按类别区分） -->
  <view class="streak-message {{showMessage ? 'show' : ''}}">
    <!-- 运动类 -->
    <block wx:if="{{categoryId === 'sports' || !categoryId}}">
      <text wx:if="{{streak === 1}}">🎉 今日运动，活力满满！</text>
      <text wx:elif="{{streak < 7}}">💪 运动 {{streak}} 天！继续燃烧！</text>
      <text wx:elif="{{streak < 14}}">🔥 连续运动 {{streak}} 天！太棒了！</text>
      <text wx:elif="{{streak < 30}}">🏆 {{streak}} 天不间断！你是运动达人！</text>
      <text wx:elif="{{streak < 100}}">👑 超级连胜 {{streak}} 天！传奇级别！</text>
      <text wx:else>🌟 {{streak}} 天！你已成为运动传奇！</text>
    </block>
    <!-- 学习类 -->
    <block wx:elif="{{categoryId === 'study'}}">
      <text wx:if="{{streak === 1}}">🎉 学习打卡，知识点亮！</text>
      <text wx:elif="{{streak < 7}}">📚 学习 {{streak}} 天！坚持就是力量！</text>
      <text wx:elif="{{streak < 14}}">🔥 连续学习 {{streak}} 天！厉害了！</text>
      <text wx:elif="{{streak < 30}}">🏆 {{streak}} 天坚持学习！你是学习达人！</text>
      <text wx:elif="{{streak < 100}}">👑 超级连胜 {{streak}} 天！博学大师！</text>
      <text wx:else>🌟 {{streak}} 天！你已成为学霸传奇！</text>
    </block>
    <!-- 生活类 -->
    <block wx:elif="{{categoryId === 'life'}}">
      <text wx:if="{{streak === 1}}">🎉 打卡生活，热爱每一天！</text>
      <text wx:elif="{{streak < 7}}">🌱 坚持 {{streak}} 天！好习惯在养成！</text>
      <text wx:elif="{{streak < 14}}">🔥 连续打卡 {{streak}} 天！生活有你更精彩！</text>
      <text wx:elif="{{streak < 30}}">🏆 {{streak}} 天不间断！你是生活达人！</text>
      <text wx:elif="{{streak < 100}}">👑 超级连胜 {{streak}} 天！活出传奇！</text>
      <text wx:else>🌟 {{streak}} 天！生活传奇非你莫属！</text>
    </block>
  </view>

  <!-- 跳过按钮 -->
  <view class="skip-btn {{canSkip ? 'show' : ''}}" bindtap="onSkip">
    <text class="btn-text">跳过</text>
  </view>
</view>
